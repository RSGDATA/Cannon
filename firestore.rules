rules_version = '2';

// Placeholder rules — locked down by default. Replace with the real model
// from docs/data-model.md once collections are finalized.
service cloud.firestore {
  match /databases/{database}/documents {
    // Deny everything by default; explicit collection rules go below.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
